# ─── OpenRouter ──────────────────────────────────────────────────────────────
# openrouter.ai → Keys
OPENROUTER_API_KEY=

# ─── GoHighLevel ─────────────────────────────────────────────────────────────
# Location-level API key: GHL sub-account → Settings → Business Profile → API Key
GHL_API_KEY=
# Found in GHL sub-account → Settings → Business Profile
GHL_LOCATION_ID=
# Contractor routing is managed via the contacts table in Supabase — no env vars needed.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase dashboard label: "Data API URL" — Project Settings → API
# NEXT_PUBLIC_ prefix is required: Next.js uses it to expose this value to browser bundles
NEXT_PUBLIC_SUPABASE_URL=
# Supabase dashboard label: "Secret key" — Project Settings → API
# Server-side only — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Supabase dashboard label: "Publishable key" — not needed yet, add when building the dashboard
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Webhook security ────────────────────────────────────────────────────────
# Set a random secret here and enter the same value in your GHL webhook config.
# Leave blank to skip signature verification (not recommended for production).
WEBHOOK_SECRET=
